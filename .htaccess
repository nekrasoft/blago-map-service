RewriteEngine On

# Единая каноническая версия: HTTPS + основной хост.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^map.blagokirov\.ru$ [NC]
RewriteRule ^ https://map.blagokirov.ru%{REQUEST_URI} [R=301,L]

# /api/config → api.php?route=config
RewriteRule ^api/config$ api.php?route=config [L,QSA]

# /api/auth → api.php?route=auth
RewriteRule ^api/auth$ api.php?route=auth [L,QSA]

# /api/login → api.php?route=login
RewriteRule ^api/login$ api.php?route=login [L,QSA]

# /api/logout → api.php?route=logout
RewriteRule ^api/logout$ api.php?route=logout [L,QSA]

# /api/bunkers → api.php?route=bunkers
RewriteRule ^api/bunkers$ api.php?route=bunkers [L,QSA]

# /api/bunkers/{id} → api.php?route=bunkers&id={id}
RewriteRule ^api/bunkers/(.+)$ api.php?route=bunkers&id=$1 [L,QSA]

# Запрет прямого доступа к config.php
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Запрет листинга директорий
Options -Indexes
