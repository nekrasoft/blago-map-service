# API-ключ Яндекс.Карт
YANDEX_MAPS_API_KEY=YOUR_KEY_HERE

# MySQL (по аналогии с tbank-service)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=map_service
MYSQL_PASSWORD=
MYSQL_DATABASE=map_service

# Авторизация (без ADMIN_PASSWORD_HASH — доступ без пароля)
# Хеш: php -r "echo password_hash('пароль', PASSWORD_DEFAULT);"
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=

# Demo-пользователь — только чтение карты
DEMO_LOGIN=demo
DEMO_PASSWORD_HASH=

# Пользователи-контрагенты (JSON-массив): [{"login":"master1","passwordHash":"$2y$...","counterpartyId":12}]
COUNTERPARTY_USERS_JSON=

# API-ключ для бота отчётов (запись без сессии)
MAP_BOT_API_KEY=

# MAX (опционально): отправка уведомлений в чат заявок при mark-filled
MAX_BOT_TOKEN=
MAX_REQUEST_CHAT_ID=

# Лог ошибок API (опционально; по умолчанию logs/api-error.log)
APP_LOG_FILE=
